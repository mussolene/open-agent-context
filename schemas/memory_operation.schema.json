{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryOperation",
  "type": "object",
  "required": ["id", "operation", "status", "actor_id", "created_at"],
  "properties": {
    "id": {"type": "string"},
    "operation": {
      "type": "string",
      "enum": [
        "memory.observe",
        "memory.propose",
        "memory.commit",
        "memory.query",
        "memory.read",
        "memory.correct",
        "memory.deprecate",
        "memory.supersede",
        "memory.forget",
        "memory.blur",
        "memory.sharpen",
        "memory.audit",
        "memory.export",
        "memory.import"
      ]
    },
    "status": {"type": "string", "enum": ["requested", "completed", "denied", "failed"]},
    "actor_id": {"type": ["string", "null"]},
    "target_id": {"type": ["string", "null"]},
    "scope": {"type": "array", "items": {"type": "string"}},
    "namespace": {"type": "string"},
    "depth": {"type": ["integer", "null"], "minimum": 0, "maximum": 5},
    "arguments": {"type": "object"},
    "result": {"type": "object"},
    "audit_event_id": {"type": ["string", "null"]},
    "created_at": {"type": "string"}
  },
  "additionalProperties": false
}
