{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryRecord",
  "type": "object",
  "required": [
    "id",
    "memory_type",
    "depth",
    "status",
    "scope",
    "namespace"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identifier for this portable OACS record."
    },
    "memory_type": {
      "type": "string",
      "description": "Portable memory classification."
    },
    "depth": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5,
      "description": "Memory depth D0-D5; D3-D5 content is not factual evidence by itself."
    },
    "lifecycle_status": {
      "type": "string",
      "description": "Memory lifecycle state used for candidate, active, deprecated, or forgotten records."
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status for this record in the portable OACS model."
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Portable scope labels that constrain where the record applies."
    },
    "namespace": {
      "type": "string",
      "description": "Logical namespace used to separate records without requiring a specific storage backend."
    },
    "owner_actor_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional actor identifier for ownership or accountability metadata."
    },
    "content": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "claim",
              "value"
            ],
            "properties": {
              "evidence_kind": {
                "type": "string"
              },
              "claim": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "source_ref": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "confidence": {
                "type": "number"
              },
              "depth": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0,
                "maximum": 5
              },
              "scope": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "participant": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "day": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "slot": {
                "type": "string"
              },
              "order": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "trajectory_step": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "attribution": {
                "type": [
                  "object",
                  "null"
                ],
                "description": "Portable provenance for the embedded evidence item: who originated it, who recorded it, and which role it plays.",
                "required": [
                  "role"
                ],
                "properties": {
                  "source_actor_id": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Actor-like identifier that originated the claim, decision, observation, or policy."
                  },
                  "source_actor_type": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "enum": [
                      "human",
                      "agent",
                      "tool",
                      "service",
                      "application",
                      "organization",
                      "system",
                      null
                    ],
                    "description": "Portable type of the originating source."
                  },
                  "recorded_by_actor_id": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Actor identifier for the runtime or agent that recorded the value into OACS."
                  },
                  "role": {
                    "type": "string",
                    "enum": [
                      "user_instruction",
                      "agent_decision",
                      "tool_observation",
                      "project_policy",
                      "human_approval",
                      "derived_memory",
                      "system_policy"
                    ],
                    "description": "How this item should be interpreted by context consumers."
                  },
                  "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Confidence in the attribution metadata, not in the underlying claim."
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "attribution": {
          "type": [
            "object",
            "null"
          ],
          "description": "Portable provenance for the memory content as a whole: who originated it, who recorded it, and which role it plays.",
          "required": [
            "role"
          ],
          "properties": {
            "source_actor_id": {
              "type": [
                "string",
                "null"
              ],
              "description": "Actor-like identifier that originated the memory content."
            },
            "source_actor_type": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "human",
                "agent",
                "tool",
                "service",
                "application",
                "organization",
                "system",
                null
              ],
              "description": "Portable type of the originating source."
            },
            "recorded_by_actor_id": {
              "type": [
                "string",
                "null"
              ],
              "description": "Actor identifier for the runtime or agent that recorded the memory into OACS."
            },
            "role": {
              "type": "string",
              "enum": [
                "user_instruction",
                "agent_decision",
                "tool_observation",
                "project_policy",
                "human_approval",
                "derived_memory",
                "system_policy"
              ],
              "description": "How this memory should be interpreted by context consumers."
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Confidence in the attribution metadata, not in the memory content."
            }
          },
          "additionalProperties": false
        }
      },
      "description": "Portable memory content envelope; protected or encrypted content must not be projected as plaintext."
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "EvidenceRef identifiers that support this record without embedding evidence payloads."
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional identifier of the memory record superseded by this record."
    }
  },
  "additionalProperties": false
}
