{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProtectedRef",
  "type": "object",
  "required": ["id", "protected_type", "label", "sensitivity", "projection", "status"],
  "properties": {
    "id": {"type": "string"},
    "protected_type": {"type": "string", "enum": ["secret", "sensitive_fact"]},
    "label": {"type": "string"},
    "sensitivity": {"type": "string", "enum": ["internal", "confidential", "restricted"]},
    "provider": {"type": "string"},
    "uri": {"type": "string"},
    "namespace": {"type": "string"},
    "scope": {"type": "array", "items": {"type": "string"}},
    "allowed_tools": {"type": "array", "items": {"type": "string"}},
    "projection": {"type": "string", "enum": ["ref_only", "redacted"]},
    "status": {"type": "string", "enum": ["active", "revoked", "expired"]}
  },
  "allOf": [
    {
      "if": {
        "properties": {"protected_type": {"const": "secret"}},
        "required": ["protected_type"]
      },
      "then": {"required": ["provider", "uri"]}
    }
  ],
  "additionalProperties": false
}
