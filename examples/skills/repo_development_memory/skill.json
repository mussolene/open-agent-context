{
  "id": "skill_repo_development_memory",
  "name": "repo_development_memory",
  "description": "Controlled repo-local OACS dogfood adapter for development memory.",
  "version": "0.1.0",
  "entrypoint": "script:scripts/repo_memory.py",
  "instructions": "Use OACS memory/context operations to capture repository development iterations as D1 episodes. Do not auto-commit D2/D3 memory.",
  "required_memory_types": ["episode"],
  "required_rules": ["rule_fuzzy_memory_not_fact"],
  "required_tools": [],
  "input_schema": {
    "type": "object",
    "required": ["action", "task"],
    "properties": {
      "action": {
        "enum": ["capture", "context", "auto_start", "auto_finish", "autorun"]
      },
      "task": { "type": "string" },
      "summary": { "type": "string" },
      "outcome": { "type": "string" },
      "command": { "type": "string" }
    }
  },
  "output_schema": {
    "type": "object"
  },
  "permissions": {
    "memory.propose": true,
    "memory.commit": true,
    "context.build": true,
    "audit.write": true
  },
  "namespace": "repo_dogfood",
  "scope": [],
  "status": "active"
}
